rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /trips/{tripId} {
      function myRole() {
        return resource.data.members[request.auth.uid];
      }

      allow read: if isSignedIn() && request.auth.uid in resource.data.members;

      // Trip creation: caller must set themselves as the sole owner.
      allow create: if isSignedIn()
        && request.resource.data.members.keys().hasOnly([request.auth.uid])
        && request.resource.data.members[request.auth.uid] == 'owner';

      allow update: if isSignedIn() && (
        // 1) Normal content edit by an existing owner/editor - membership & codes untouched.
        (myRole() in ['owner', 'editor']
          && request.resource.data.members == resource.data.members
          && request.resource.data.codes == resource.data.codes)
        ||
        // 2) Owner managing members / regenerating codes - trip content untouched.
        (myRole() == 'owner'
          && request.resource.data.name == resource.data.name
          && request.resource.data.startDate == resource.data.startDate
          && request.resource.data.currency == resource.data.currency
          && request.resource.data.days == resource.data.days
          && request.resource.data.packing == resource.data.packing
          && request.resource.data.attractionIdeas == resource.data.attractionIdeas)
        ||
        // 3) Joining via an invite code - only the caller's own membership entry
        //    may be added, and only if a matching tripCodes document grants it.
        //    (Firestore rules can't "search" for a matching code - the client must
        //    supply the exact code it used, in `lastJoinCode`, so the rule can
        //    look that single document up and verify it really grants this role.)
        (!(request.auth.uid in resource.data.members)
          && request.resource.data.members.diff(resource.data.members).affectedKeys().hasOnly([request.auth.uid])
          && request.resource.data.get('lastJoinCode', '') != ''
          && get(/databases/$(database)/documents/tripCodes/$(request.resource.data.lastJoinCode)).data.tripId == tripId
          && get(/databases/$(database)/documents/tripCodes/$(request.resource.data.lastJoinCode)).data.role == request.resource.data.members[request.auth.uid])
      );

      allow delete: if isSignedIn() && myRole() == 'owner';
    }

    // Lookup table: code (document ID) -> { tripId, role }.
    // `get` only - never `list` - so codes can't be enumerated, only used if you
    // already know the exact string (same trust model as a bearer link/password).
    match /tripCodes/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow update: if false;

      allow create: if isSignedIn()
        && get(/databases/$(database)/documents/trips/$(request.resource.data.tripId)).data.members[request.auth.uid] == 'owner';

      allow delete: if isSignedIn()
        && get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.members[request.auth.uid] == 'owner';
    }
  }
}
